# Lark App credentials (from open.larksuite.com or open.feishu.cn)
LARK_APP_ID=cli_your_app_id
LARK_APP_SECRET=your_app_secret
LARK_ENCRYPT_KEY=

# Set to "feishu" to use China domestic domain
LARK_DOMAIN=

# Bot display name
BOT_NAME=Marvin

# Admin user open_id (for interrupt control)
ADMIN_OPEN_ID=

# Claude Code working directory (defaults to project root)
CLAUDE_CWD=

# Timeouts in milliseconds
CLAUDE_TIMEOUT_MS=600000
CLAUDE_IDLE_TIMEOUT_MS=3600000
CLAUDE_STARTUP_TIMEOUT_MS=300000
CLAUDE_MAX_TURNS=200
